# ─────────────────────────────────────────────────────────────
# Landy's Pro — Environment variables
# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored. NEVER commit real secrets.
# The app runs fully on MOCK integrations if the *_MOCK flags are "true",
# so you can develop before wiring live keys.
# ─────────────────────────────────────────────────────────────


# ═══════════════════════════════════════════════════════════
# DATABASE — Supabase Postgres
# ═══════════════════════════════════════════════════════════
# Supabase gives you TWO connection strings. You need BOTH.
#
#   • DATABASE_URL  → the POOLED connection (port 6543, "Transaction" pooler).
#                     Used by the app at runtime. Required for serverless
#                     (Vercel) so you don't exhaust Postgres connections.
#                     Must include `?pgbouncer=true&connection_limit=1`.
#
#   • DIRECT_URL    → the DIRECT connection (port 5432).
#                     Used by Prisma for `migrate` / `db push` / introspection,
#                     which cannot run through the pooler.
#
# In schema.prisma:
#   datasource db {
#     provider  = "postgresql"
#     url       = env("DATABASE_URL")   // pooled, runtime
#     directUrl = env("DIRECT_URL")     // direct, migrations
#   }
#
# Find both in Supabase → Project Settings → Database → Connection string.
# Replace [PROJECT-REF], [PASSWORD], and [REGION] with your values.

DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"


# ═══════════════════════════════════════════════════════════
# APP
# ═══════════════════════════════════════════════════════════
# Public base URL of the app. Used to build tokenized SMS accept links.
# Local: http://localhost:3000   Prod: https://prolandys.com (or the Vercel URL)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Node environment: development | production
NODE_ENV="development"


# ═══════════════════════════════════════════════════════════
# AUTH — Clerk
# ═══════════════════════════════════════════════════════════
# Dashboard → API Keys. Contractor + admin auth.
# Note: the tokenized SMS accept flow is intentionally UNAUTHENTICATED
# (low-tech users), so it does NOT depend on Clerk.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"


# ═══════════════════════════════════════════════════════════
# PAYMENTS — Stripe (wallet top-ups)
# ═══════════════════════════════════════════════════════════
# STRIPE_MOCK=true  → simulate top-ups with no keys (logs to console). DEFAULT.
# STRIPE_MOCK=false → real Stripe. Use TEST keys (sk_test_/pk_test_) in dev; the
#   wallet is credited ONLY by the signature-verified webhook below, never by the
#   browser redirect. LIVE keys (sk_live_) are swapped in only at launch.
#
# Local webhook testing (Stripe CLI):
#   stripe login
#   stripe listen --forward-to localhost:3000/api/stripe/webhook
#   # copy the printed whsec_... into STRIPE_WEBHOOK_SECRET, restart dev
#   stripe trigger checkout.session.completed
#   # fire it TWICE to prove idempotency: the wallet is credited only once.
# Test cards: 4242 4242 4242 4242 (success), 4000 0000 0000 0002 (decline).
STRIPE_MOCK="true"
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# From `stripe listen` (local) or Stripe → Developers → Webhooks (deployed).
STRIPE_WEBHOOK_SECRET="whsec_..."


# ═══════════════════════════════════════════════════════════
# SMS — Twilio (lead notifications + tokenized accept link)
# ═══════════════════════════════════════════════════════════
# Set TWILIO_MOCK=true to log SMS to console instead of sending.
# ⚠️ US A2P 10DLC: sending SMS to US numbers requires brand + campaign
#    registration BEFORE production. This has lead time — start it early.
TWILIO_MOCK="true"
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="..."
TWILIO_FROM_NUMBER="+1..."          # your Twilio sending number
TWILIO_MESSAGING_SERVICE_SID="MG..." # optional; preferred for A2P at scale


# ═══════════════════════════════════════════════════════════
# EMAIL — Resend (lead + acceptance notifications)
# ═══════════════════════════════════════════════════════════
# Set RESEND_MOCK=true to log emails to console instead of sending.
RESEND_MOCK="true"
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="leads@prolandys.com"  # must be a verified domain in Resend


# ═══════════════════════════════════════════════════════════
# LEAD LOGIC DEFAULTS (also editable at runtime via AppSetting in admin)
# ═══════════════════════════════════════════════════════════
# These seed the AppSetting table. Admin can change them in-app afterward;
# the env values are only the initial defaults on first seed.
DEFAULT_MAX_LEAD_RECIPIENTS="3"   # shared leads: up to N contractors per lead
DEFAULT_LEAD_EXPIRY_HOURS="48"    # a lead can no longer be accepted after this


# ═══════════════════════════════════════════════════════════
# SECURITY — estimate form intake
# ═══════════════════════════════════════════════════════════
# Basic spam protection for the public estimate form (default ON).
# Landon may relax/tighten after review.
FORM_SPAM_PROTECTION="true"       # honeypot + rate limit + format validation
FORM_RATE_LIMIT_PER_HOUR="10"     # max submissions per IP per hour
