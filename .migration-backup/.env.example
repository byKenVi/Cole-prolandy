# ─────────────────────────────────────────────────────────────
# Landy's Pro — Environment variables (EXAMPLE / TEMPLATE)
# Copy this file to `.env` and fill in real values. `.env` is git-ignored.
# NEVER commit real secrets. All placeholder values below are safe/fake.
# The app runs fully on MOCK integrations while the *_MOCK flags are "true".
# ─────────────────────────────────────────────────────────────


# ═══════════════════════════════════════════════════════════
# CORE
# ═══════════════════════════════════════════════════════════
# Do not define NODE_ENV; Next.js sets it for each command.
# Public base URL of the app; used to build tokenized SMS accept links.
NEXT_PUBLIC_APP_URL="http://localhost:3000"


# ═══════════════════════════════════════════════════════════
# DATABASE — Supabase Postgres (BOTH are required)
# ═══════════════════════════════════════════════════════════
# DATABASE_URL → POOLED connection (port 6543); used by the app at runtime.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1"
# DIRECT_URL → DIRECT connection (port 5432); used by Prisma migrate/introspect.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"


# ═══════════════════════════════════════════════════════════
# MEDIA — persistent contractor logos (Supabase Storage)
# ═══════════════════════════════════════════════════════════
SUPABASE_URL="https://PROJECT_REF.supabase.co"
# Server-only admin credential. Never prefix this variable with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY="<your-supabase-service-role-key>"


# ═══════════════════════════════════════════════════════════
# AUTH — Clerk
# ═══════════════════════════════════════════════════════════
# REQUIRED = "clerk" in production. Any other value uses insecure DEV auth and the
# app REFUSES to boot in production (fail-closed). Use "clerk" or "dev".
AUTH_MODE="dev"
# Clerk API keys (Dashboard → API Keys). Required when AUTH_MODE=clerk.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="<your-clerk-publishable-key>"
CLERK_SECRET_KEY="<your-clerk-secret-key>"
# Comma-separated admin emails; a signed-in Clerk user with one of these is admin.
ADMIN_EMAILS="admin@example.com"
# Clerk hosted sign-in/up routes and post-auth redirects.
# IMPORTANT: fallback must be /post-auth (not /home) so admins are routed to
# /admin after sign-in. The SignIn/SignUp components also force /post-auth.
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/post-auth"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/post-auth"


# ═══════════════════════════════════════════════════════════
# PAYMENTS — Stripe (wallet top-ups)
# ═══════════════════════════════════════════════════════════
# STRIPE_MOCK="true" simulates Stripe; "false" uses the real API with the keys below.
STRIPE_MOCK="true"
# Stripe secret key (test starts sk_test_, live starts sk_live_). Required when not mocked.
STRIPE_SECRET_KEY="<your-stripe-secret-key>"
# Webhook signing secret (Stripe → Developers → Webhooks). Verifies top-up events.
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxxxxxx"


# ═══════════════════════════════════════════════════════════
# SMS — Twilio (lead notifications + tokenized accept link)
# ═══════════════════════════════════════════════════════════
# TWILIO_MOCK="true" logs SMS to console instead of sending.
TWILIO_MOCK="true"
# Twilio account SID. Required when not mocked.
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxx"
# Twilio auth token. Required when not mocked.
TWILIO_AUTH_TOKEN="xxxxxxxxxxxxxxxxxxxxxxxx"
# Sending phone number in E.164 (trial accounts use this). Do NOT use TWILIO_FROM_NUMBER.
TWILIO_FROM="+15555550123"
# Optional. Only set a real MGxxxx from Twilio Console (A2P). Leave unset for trial.
# TWILIO_MESSAGING_SERVICE_SID="MGxxxxxxxxxxxxxxxxxxxxxxxx"


# ═══════════════════════════════════════════════════════════
# EMAIL — Resend (lead + acceptance notifications)
# ═══════════════════════════════════════════════════════════
# RESEND_MOCK="true" logs emails to console instead of sending.
RESEND_MOCK="true"
# Resend API key. Required when not mocked.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"
# From address; must be a verified domain in Resend.
RESEND_FROM="leads@example.com"


# ═══════════════════════════════════════════════════════════
# SECURITY
# ═══════════════════════════════════════════════════════════
# Estimate-form spam protection (honeypot + rate limit). Configurable in dev;
# ALWAYS forced ON in production regardless of this flag.
FORM_SPAM_PROTECTION="true"
# Max estimate submissions per IP per hour.
FORM_RATE_LIMIT_PER_HOUR="10"
# Bearer secret for the cron expiry-sweep endpoint. REQUIRED in production — the
# endpoint fails closed (401) if this is unset in prod.
CRON_SECRET="replace-with-a-long-random-string"
